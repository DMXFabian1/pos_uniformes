# Copia este archivo como `pos_uniformes.env` junto al ejecutable o en la raiz del proyecto.
# La app lo leera automaticamente cuando no existan variables de entorno del sistema.

POS_UNIFORMES_DB_HOST=localhost
POS_UNIFORMES_DB_PORT=5432
POS_UNIFORMES_DB_NAME=pos_uniformes
POS_UNIFORMES_DB_USER=postgres
POS_UNIFORMES_DB_PASSWORD=postgres
POS_UNIFORMES_DB_ECHO=0
POS_UNIFORMES_AUTO_CREATE_SCHEMA=0
# Opcional: segunda copia del respaldo automatico en carpeta sincronizada o disco externo.
POS_UNIFORMES_BACKUP_EXTERNAL_DIR=
